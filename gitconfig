[user]
    email = 
    name = 

[credential]
    helper = cache --timeout=259200

[alias]
    d = diff
    co = checkout
    cob = checkout -b
    ci = commit
    cim = commit -m
    cia = commit --amend
    s = status
    st = status

    rh = reset --hard

    br = branch
    brv = branch -vvaa

    h = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short --decorate --no-merges
    hm = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short --decorate 
    lp = log -p

    r = rebase
    rc = rebase --continue
    ra = rebase --abort

    last = log -1
    type = cat-file -t
    dump = cat-file -p

[push]
    default = simple # matching < 2.0 || simple >= 2.0
    followTags = true
    autoSetupRemote = true

[core]
    editor = vim
    quotepath = false # решение проблем с русскими буквами файлов
    fileMode = false
    
[color]
    diff = auto
    status = auto
    branch = auto
    interactive = auto
    ui = true
    pager = true
[color "branch"]
    current = yellow
    local = green
    remote = cyan

[http]
    sslVerify = false

[gc]
    reflogExpire = 200
    reflogExpireUnreachable = 90

[diff]
    tool = /usr/bin/meld

